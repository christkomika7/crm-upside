generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator prismabox {
  provider                    = "prismabox"
  typeboxImportDependencyName = "elysia"
  typeboxImportVariableName   = "t"
  inputModel                  = true
  output                      = "../src/generated/prismabox"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum DeletionState {
  NOTHING
  WAIT
  TERMINED
}

enum PaymentType {
  CASH
  CHECK
  BANK
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

enum ContractType {
  CONTRACT
  MANDATE
}

enum DeletionType {
  OWNER
  BUILDING
  TENANT
  UNIT
  RENTAL
  RESERVATION
  PROPERTY_MANAGEMENT
  PRODUCT_SERVICE
  INVOICING
  QUOTE
  CONTRACT
  CHECK_IN
  APPOINTMENT
  SERVICE_PROVIDER
  COMMUNICATION
}

enum ItemStatus {
  USED
  IGNORE
}

enum ClientType {
  OWNER
  TENANT
}

enum DiscountType {
  PERCENT
  MONEY
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  createdAt     DateTime      @default(now())
  firstname     String        @default("")
  lastname      String        @default("")
  name          String
  role          Role          @default(USER)
  emailVerified Boolean       @default(false)
  image         String?
  updatedAt     DateTime      @updatedAt
  sessions      Session[]
  accounts      Account[]
  appointments  Appointment[]

  permission Permission?
  deletions  Deletion[]

  @@map("user")
}

model Permission {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  permissions Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("permission")
}

model Cumul {
  id    String @id @default(cuid())
  name  String
  value String
  taxes Tax[]

  @@map("cumul")
}

model Tax {
  id    String @id @default(cuid())
  name  String @unique
  value String

  cumuls Cumul[]

  @@map("tax")
}

model Note {
  id      String @id @default(cuid())
  invoice String
  quote   String

  @@map("note")
}

model Reference {
  id      String @id @default(cuid())
  invoice String
  quote   String

  @@map("reference")
}

model Appearence {
  id   String @id @default(cuid())
  logo String

  @@map("appearence")
}

model Building {
  id               String   @id @default(cuid())
  reference        String   @unique
  name             String
  location         String
  constructionDate DateTime
  door             Int
  parkingPrice     Decimal  @default(0) @db.Decimal(15, 2)
  security         Boolean  @default(false)
  camera           Boolean  @default(false)
  elevator         Boolean  @default(false)
  parking          Boolean  @default(false)
  pool             Boolean  @default(false)
  generator        Boolean  @default(false)
  waterBorehole    Boolean  @default(false)
  gym              Boolean  @default(false)
  garden           Boolean  @default(false)
  status           String[]
  map              String
  photos           String[]
  deeds            String[]
  documents        String[]

  isDeleting Boolean @default(false)

  lotTypes LotType[]
  units    Unit[]

  ownerId String?
  owner   Owner?  @relation(fields: [ownerId], references: [id])

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  propertyManagements PropertyManagement[]
  contracts           Contract[]

  @@map("building")
}

model Unit {
  id           String   @id @default(cuid())
  reference    String   @unique
  rentalStatus String
  surface      String
  rooms        String
  rent         Decimal
  furnished    String
  wifi         Boolean
  water        Boolean
  electricity  Boolean
  tv           Boolean
  charges      Decimal
  documents    String[]

  isDeleting Boolean @default(false)

  rentals Rental[]

  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String

  typeId String
  type   Type   @relation(fields: [typeId], references: [id])

  reservations        Reservation[]
  propertyManagements PropertyManagement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("unit")
}

model LotType {
  id   String @id @default(cuid())
  name String @unique

  building Building[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lot_type")
}

model Profession {
  id   String @id @default(cuid())
  name String @unique

  serviceProviders ServiceProvider[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profession")
}

model Type {
  id   String @id @default(cuid())
  name String @unique

  unit Unit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("type")
}

model Owner {
  id         String @id @default(cuid())
  reference  String @unique
  firstname  String
  lastname   String
  company    String
  phone      String
  email      String
  address    String
  actionnary String

  isDeleting Boolean @default(false)

  buildings Building[]

  bankInfo  String
  documents String[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  invoices     Invoice[]
  quotes       Quote[]
  appointments Appointment[]

  @@map("owner")
}

model Tenant {
  id            String   @id @default(cuid())
  firstname     String
  lastname      String
  company       String
  phone         String
  email         String
  address       String
  maritalStatus String?
  income        Decimal  @default(0) @db.Decimal(15, 2)
  bankInfo      String
  paymentMode   String
  documents     String[]

  isDeleting Boolean @default(false)

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rentals      Rental[]
  invoices     Invoice[]
  quotes       Quote[]
  appointments Appointment[]

  @@map("tenant")
}

model Rental {
  id String @id @default(cuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  isDeleting Boolean @default(false)

  price Decimal  @default(0) @db.Decimal(15, 2)
  start DateTime
  end   DateTime

  contracts Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental")
}

model Reservation {
  id         String   @id @default(cuid())
  name       String
  contact    String
  start      DateTime
  end        DateTime
  price      Decimal  @default(0) @db.Decimal(15, 2)
  isDeleting Boolean  @default(false)

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reservation")
}

model PropertyManagement {
  id String @id @default(cuid())

  buildingId String
  building   Building @relation(fields: [buildingId], references: [id])

  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  administrativeManagement Boolean           @default(false)
  technicalManagement      Boolean           @default(false)
  services                 PersonalService[]

  start        DateTime
  end          DateTime
  observations String?
  active       Boolean  @default(false)
  isDeleting   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@map("property_management")
}

model ProductService {
  id          String  @id @default(cuid())
  reference   String  @unique
  description String
  hasTax      Boolean @default(false)
  price       Decimal @default(0) @db.Decimal(15, 2)
  isDeleting  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  items     Item[]

  @@map("product_service")
}

model Item {
  id               String         @id @default(cuid())
  quantity         Int
  productServiceId String
  productService   ProductService @relation(fields: [productServiceId], references: [id])
  price            Decimal        @default(0) @db.Decimal(15, 2)
  description      String
  reference        String
  hasTax           Boolean        @default(false)
  status           ItemStatus     @default(USED)

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("item")
}

model Invoice {
  id           String        @id @default(cuid())
  reference    Int           @default(autoincrement())
  price        Decimal       @default(0) @db.Decimal(15, 2)
  amountPaid   Decimal       @default(0) @db.Decimal(15, 2)
  discount     Decimal       @default(0) @db.Decimal(15, 2)
  status       InvoiceStatus @default(PENDING)
  discountType DiscountType  @default(PERCENT)
  hasTax       Boolean       @default(false)
  type         ClientType
  ownerId      String?
  owner        Owner?        @relation(fields: [ownerId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  items    Item[]

  note String?

  start DateTime
  end   DateTime

  isDeleting Boolean @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]

  @@map("invoice")
}

model Quote {
  id           String       @id @default(cuid())
  reference    Int          @default(autoincrement())
  price        Decimal      @default(0) @db.Decimal(15, 2)
  discount     Decimal      @default(0) @db.Decimal(15, 2)
  discountType DiscountType @default(PERCENT)
  hasTax       Boolean      @default(false)
  type         ClientType
  isComplete   Boolean      @default(false)

  ownerId String?
  owner   Owner?  @relation(fields: [ownerId], references: [id])

  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  items Item[]

  note String?

  start DateTime
  end   DateTime

  isDeleting Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quote")
}

model ServiceProvider {
  id String @id @default(cuid())

  firstname      String
  lastname       String
  company        String
  phone          String
  email          String
  address        String
  nif            String
  registerNumber String
  paymentMode    String
  note           Float
  comment        String?

  isDeleting Boolean @default(false)

  profession   Profession @relation(fields: [professionId], references: [id])
  professionId String

  rcc            String?
  idCard         String?
  taxCertificate String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("service_provider")
}

model Contract {
  id   String       @id @default(cuid())
  type ContractType

  start DateTime
  end   DateTime

  rentalId String?
  rental   Rental? @relation(fields: [rentalId], references: [id])

  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id])

  isCanceled Boolean @default(false)
  isDeleting Boolean @default(false)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("contract")
}

model CheckInOut {
  id String @id @default(cuid())

  isChecked  Boolean @default(false)
  isDeleting Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("check_in_out")
}

model Appointment {
  id   String     @id @default(cuid())
  type ClientType

  ownerId     String?
  owner       Owner?  @relation(fields: [ownerId], references: [id])
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  teamMembers User[]

  date       DateTime
  hour       String
  minutes    String
  address    String
  subject    String
  note       String
  isComplete Boolean  @default(false)

  isDeleting Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointment")
}

model Payment {
  id        String      @id @default(cuid())
  reference Int         @default(autoincrement())
  amount    Decimal     @default(0) @db.Decimal(15, 2)
  type      PaymentType
  date      DateTime    @default(now())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payment")
}

model PersonalService {
  id   String @id @default(cuid())
  name String @unique

  propertyManagements PropertyManagement[]

  @@map("personal_service")
}

model Deletion {
  id       String        @id @default(cuid())
  type     DeletionType
  recordId String        @unique
  state    DeletionState @default(NOTHING)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("deletion")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
